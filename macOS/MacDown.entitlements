<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Not sandboxed: distributed outside the Mac App Store via Developer ID.
	     Hardened Runtime is enabled at sign time with `codesign --options runtime`. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
</dict>
</plist>
